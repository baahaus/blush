{
  "name": "@blush/cli",
  "version": "0.1.0",
  "description": "Blush CLI -- team coding agent from ap.haus",
  "type": "module",
  "bin": {
    "blush": "dist/bin.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./sdk": {
      "import": "./dist/sdk.js",
      "types": "./dist/sdk.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@blush/ai": "workspace:*",
    "@blush/core": "workspace:*",
    "@blush/team": "workspace:*",
    "@blush/tui": "workspace:*",
    "@sinclair/typebox": "^0.34.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
